{
  "name": "lawyer-manager",
  "version": "2.0.0",
  "main": "main.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "test": "mocha \"tests/unit/*.test.js\" --timeout 30000",
    "test:auth": "mocha \"tests/unit/auth.test.js\"",
    "test:db": "mocha \"tests/unit/database.test.js\"",
    "test:cases": "mocha \"tests/unit/cases.test.js\"",
    "test:clients": "mocha \"tests/unit/clients.test.js\"",
    "test:docs": "mocha \"tests/unit/documents.test.js\"",
    "test:tasks": "mocha \"tests/unit/tasks.test.js\"",
    "test:search": "mocha \"tests/unit/search.test.js\"",
    "test:ipc": "mocha \"tests/unit/ipc-handlers.test.js\"",
    "test:e2e": "npx playwright test",
    "test:legacy": "node test/password.test.js",
    "lint": "eslint . --ext .js",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "build": {
    "appId": "com.avocat.manager",
    "productName": "مدير مكتب المحامي",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ar",
        "fr"
      ],
      "language": "1033"
    },
    "files": [
      "!modules_backup/**"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm",
      "node_modules/tesseract.js-core/*.wasm"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.3",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.1.200",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "electron": "^42.4.1",
    "electron-builder": "^24.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.7.6",
    "prettier": "^3.9.4"
  },
  "allowScripts": {},
  "overrides": {
    "serialize-javascript": "^7.0.7",
    "diff": "^8.0.3"
  }
}
